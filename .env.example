# Runtime
ENVIRONMENT=local
APP_NAME=GrantAtlas
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
PUBLIC_SITE_URL=http://localhost:3000
PUBLIC_HOSTNAME=localhost
APP_HOSTNAME=app.localhost
API_HOSTNAME=api.localhost
NEXT_PUBLIC_APP_URL=http://localhost:3000
CADDY_ACME_EMAIL=admin@grantatlas.ai

# Security
SECRET_KEY=change-this-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1,api.localhost,api

# Database / queue / storage
POSTGRES_PASSWORD=grantatlas-local-dev
DATABASE_URL=postgresql+psycopg://grantatlas:grantatlas-local-dev@db:5432/grantatlas
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=grantatlas
MINIO_SECRET_KEY=grantatlas-local-minio-secret
MINIO_BUCKET=grantatlas

# Grants.gov
GRANTS_GOV_SEARCH_URL=https://api.grants.gov/v1/api/search2
GRANTS_GOV_FETCH_LIMIT=50

# SAM.gov contracts v2
SAM_GOV_API_KEY=
SAM_GOV_OPPORTUNITIES_URL=https://api.sam.gov/opportunities/v2/search
SAM_GOV_FETCH_LIMIT=50
SAM_GOV_DEFAULT_POSTED_DAYS=30

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_TRIAL_DAYS=14

# Resend
RESEND_API_KEY=
EMAIL_FROM=GrantAtlas <notifications@grantatlas.ai>

# Super admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=owner@gratitech.org
BOOTSTRAP_ADMIN_PASSWORD=local-dev-change-me-only

# Server-to-server URL the web container uses to reach the API
API_SERVER_URL=http://api:8000

# AI features (optional; scoring narratives are skipped when unset)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Local AI provider (no usage costs): set AI_PROVIDER=ollama and run `ollama serve`
AI_PROVIDER=anthropic
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:12b
