# Runtime
ENVIRONMENT=production
APP_NAME=GrantAtlas
API_BASE_URL=https://api.grantatlas.ai
WEB_BASE_URL=https://app.grantatlas.ai
PUBLIC_SITE_URL=https://grantatlas.ai
PUBLIC_HOSTNAME=grantatlas.ai
APP_HOSTNAME=app.grantatlas.ai
API_HOSTNAME=api.grantatlas.ai
NEXT_PUBLIC_APP_URL=https://app.grantatlas.ai
CADDY_ACME_EMAIL=admin@grantatlas.ai

# Security
SECRET_KEY=replace-with-a-long-random-production-secret
ACCESS_TOKEN_EXPIRE_MINUTES=720
COOKIE_SECURE=true
CORS_ORIGINS=https://grantatlas.ai,https://app.grantatlas.ai

# Database / queue / storage
DATABASE_URL=postgresql+psycopg://grantatlas:replace-db-password@db:5432/grantatlas
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=grantatlas
MINIO_SECRET_KEY=replace-minio-secret
MINIO_BUCKET=grantatlas

# Grants.gov
GRANTS_GOV_SEARCH_URL=https://api.grants.gov/v1/api/search2
GRANTS_GOV_FETCH_LIMIT=50

# SAM.gov contracts v2
SAM_GOV_API_KEY=
SAM_GOV_OPPORTUNITIES_URL=https://api.sam.gov/opportunities/v2/search
SAM_GOV_FETCH_LIMIT=50
SAM_GOV_DEFAULT_POSTED_DAYS=30

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PROFESSIONAL_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=
STRIPE_TRIAL_DAYS=14

# Resend
RESEND_API_KEY=
EMAIL_FROM=GrantAtlas <notifications@grantatlas.ai>

# Super admin bootstrap
BOOTSTRAP_ADMIN_EMAIL=owner@gratitech.org
BOOTSTRAP_ADMIN_PASSWORD=replace-bootstrap-password
